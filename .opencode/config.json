{
  "project": "XRayMOD",
  "version": "2.0.0",
  "description": "Modular proxy management panel on Cloudflare Workers",
  "docs": {
    "architecture": ".opencode/architecture.md",
    "endpoints": ".opencode/endpoints.md",
    "libraries": ".opencode/libraries.md",
    "deployment": ".opencode/deployment.md",
    "stealth": ".opencode/stealth.md",
    "workflow": ".opencode/workflow.md"
  },
  "rules": {
    "ponytail": "full",
    "language": "fa",
    "no_comments_unless": "why_is_non_obvious",
    "no_ascii_boxes": true
  },
  "build": {
    "worker": "bash build-worker.sh",
    "frontend": "cd frontend && npm run build",
    "installer": "uv run xraymod-install"
  }
}
