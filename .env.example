# XrayMOD Cloudflare Worker Environment Variables
# Set these in wrangler.toml [vars] or via Wrangler dashboard

# Admin password (set on first deploy via /install wizard)
ADMIN_PASSWORD=

# VLESS UUID (auto-generated if not set)
UUID=

# Enable Telegram bot integration (requires external Node server)
ENABLE_TELEGRAM=false

# Enable TON wallet integration (requires external Node server)
ENABLE_TON_WALLET=false

# External server URL for Telegram/TON bridge features
EXTERNAL_SERVER_URL=
